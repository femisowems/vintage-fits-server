{
  "name": "vintage-fits-server",
  "version": "2.0.0",
  "description": "Vintage Fits — Keystone.js v9 GraphQL API & Admin UI backend with MongoDB, Cloudinary, Stripe, and Nodemailer",
  "private": true,
  "author": "Femi Sowemimo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/femisowemimo/vintage.git",
    "directory": "vintage-fits-server"
  },
  "keywords": [
    "keystone",
    "keystone-next",
    "graphql",
    "mongodb",
    "e-commerce",
    "cms",
    "stripe",
    "cloudinary"
  ],
  "scripts": {
    "dev": "NODE_OPTIONS=--openssl-legacy-provider keystone-next dev",
    "build": "NODE_OPTIONS=--openssl-legacy-provider keystone-next build",
    "start": "NODE_OPTIONS=--openssl-legacy-provider keystone-next start",
    "seed-data": "NODE_OPTIONS=--openssl-legacy-provider keystone-next dev --seed-data",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "type-check": "tsc --noEmit",
    "postinstall": "node -e \"const fs=require('fs');const p='node_modules/extract-files/package.json';if(fs.existsSync(p)){const d=JSON.parse(fs.readFileSync(p));if(d.exports){delete d.exports;fs.writeFileSync(p,JSON.stringify(d,null,2))}}\""
  },
  "dependencies": {
    "@keystone-next/admin-ui": "^8.0.1",
    "@keystone-next/auth": "^14.0.0",
    "@keystone-next/cloudinary": "^2.0.9",
    "@keystone-next/fields": "^4.1.1",
    "@keystone-next/keystone": "^9.3.0",
    "@keystone-next/types": "^12.0.0",
    "@keystonejs/server-side-graphql-client": "^1.1.2",
    "@types/nodemailer": "^6.4.0",
    "dotenv": "^8.2.0",
    "next": "^10.0.5",
    "nodemailer": "^6.4.17",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "stripe": "^8.130.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^4.9.0",
    "@typescript-eslint/parser": "^4.9.0",
    "babel-eslint": "^10.1.0",
    "eslint": "^7.14.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-airbnb-typescript": "^12.0.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-config-wesbos": "^2.0.0-beta.4",
    "eslint-plugin-html": "^6.1.1",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-react": "^7.21.5",
    "eslint-plugin-react-hooks": "^4.2.0",
    "prettier": "^2.2.1",
    "typescript": "^4.1.2"
  },
  "eslintConfig": {
    "extends": "wesbos/typescript.js",
    "rules": {
      "@typescript-eslint/no-unsafe-assignment": 0
    }
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": 14,
            "browsers": [
              "last 2 chrome versions",
              "last 2 firefox versions",
              "last 2 safari versions",
              "last 2 edge versions"
            ]
          }
        }
      ],
      "@babel/preset-react",
      "@babel/preset-typescript"
    ]
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
